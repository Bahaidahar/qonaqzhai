# qonaqzhai backend env (copy to .env)

# HTTP listen address
ADDR=:8080

# SQLite database file path
DB_PATH=qonaqzhai.db

# Frontend origin allowed by CORS
CORS_ORIGIN=http://localhost:3000

# JWT signing secret — REQUIRED in production.
# Generate with: openssl rand -hex 32
# If empty, a random one is generated on each restart (tokens invalidate).
JWT_SECRET=

# Gemini AI — get free API key at https://aistudio.google.com/apikey
# If empty, /api/chat falls back to keyword-based mock responses.
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash
