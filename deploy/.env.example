# Required for production. Generate with: openssl rand -hex 32
JWT_SECRET=replace_me_with_long_random_secret

# Optional admin seed (idempotent on restart). Skip both to disable.
ADMIN_EMAIL=admin@qonaqzhai.kz
ADMIN_PASSWORD=replace_me

# SMTP for password reset emails. Leave blank to disable delivery.
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=

# PayBox credentials. Leave blank to use the Mock gateway (always-captured).
PAYBOX_MERCHANT_ID=
PAYBOX_SECRET_KEY=
PAYBOX_SANDBOX=true

# Public CORS origin (mobile + frontend). "*" only for local dev.
CORS_ORIGIN=*

# Host port the gateway binds to.
GATEWAY_PUBLIC_PORT=8080
